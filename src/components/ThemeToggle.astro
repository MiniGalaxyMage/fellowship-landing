---
---

<button
  class="theme-toggle flex items-center justify-center w-8 h-8 rounded-full text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 bg-slate-200/60 dark:bg-white/[0.06] hover:bg-slate-200 dark:hover:bg-white/[0.12] transition-colors duration-200"
  type="button"
  aria-label="Toggle theme"
>
  <!-- Sun icon (shown when theme = light) -->
  <svg class="theme-icon-light w-[18px] h-[18px]" style="display:none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <circle cx="12" cy="12" r="5"/>
    <path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
  </svg>
  <!-- Moon icon (shown when theme = dark) -->
  <svg class="theme-icon-dark w-[18px] h-[18px]" style="display:none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <!-- Monitor icon (shown when theme = system) -->
  <svg class="theme-icon-system w-[18px] h-[18px]" style="display:none" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
    <path d="M8 21h8m-4-4v4"/>
  </svg>
</button>

<script is:inline>
(function() {
  function getTheme() {
    return localStorage.getItem('theme') || 'system';
  }

  function applyTheme(theme) {
    var isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    document.documentElement.classList.toggle('dark', isDark);
  }

  function updateIcons(theme) {
    document.querySelectorAll('.theme-toggle').forEach(function(btn) {
      var light = btn.querySelector('.theme-icon-light');
      var dark = btn.querySelector('.theme-icon-dark');
      var system = btn.querySelector('.theme-icon-system');
      if (light) light.style.display = theme === 'light' ? '' : 'none';
      if (dark) dark.style.display = theme === 'dark' ? '' : 'none';
      if (system) system.style.display = theme === 'system' ? '' : 'none';
    });
  }

  function initToggles() {
    var theme = getTheme();
    updateIcons(theme);

    document.querySelectorAll('.theme-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var current = getTheme();
        var next = current === 'dark' ? 'light' : current === 'light' ? 'system' : 'dark';
        localStorage.setItem('theme', next);
        applyTheme(next);
        updateIcons(next);
        // Smooth transition
        document.documentElement.classList.add('theme-transitioning');
        setTimeout(function() {
          document.documentElement.classList.remove('theme-transitioning');
        }, 350);
      });
    });
  }

  // Listen for OS preference changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
    if (getTheme() === 'system') {
      applyTheme('system');
    }
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToggles);
  } else {
    initToggles();
  }
})();
</script>
