                </p>
              </div>
            </div>

            <div class="border-t border-slate-800/60"></div>

            <div class="how-step">
              <div class="step-number">2</div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                  <code class="text-cyan-400 font-medium">fellowship run "task"</code>
