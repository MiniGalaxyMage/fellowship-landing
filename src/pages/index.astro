<style is:global>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  /* Theme transition */
  html.theme-transitioning,
  html.theme-transitioning *,
  html.theme-transitioning *::before,
  html.theme-transitioning *::after {
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease !important;
    transition-delay: 0s !important;
  }

  .bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(124,58,237,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,58,237,0.03) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  .gradient-text-hero {
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 30%, #2dd4bf 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ---- Terminal CTA ---- */
  .terminal-cta {
    display: flex; align-items: center;
    background: #060b17;
    border: 1px solid rgba(45,212,191,0.3);
    border-radius: 12px;
    padding: 16px 20px;
    box-shadow: 0 0 40px rgba(45,212,191,0.08), 0 0 80px rgba(45,212,191,0.04);
    animation: ctaGlow 3s ease-in-out infinite;
  }
  @keyframes ctaGlow {
    0%,100% { box-shadow: 0 0 40px rgba(45,212,191,0.08), 0 0 80px rgba(45,212,191,0.04); }
    50% { box-shadow: 0 0 50px rgba(45,212,191,0.15), 0 0 100px rgba(45,212,191,0.07); }
  }

  .copy-btn {
    background: rgba(45,212,191,0.12); border: 1px solid rgba(45,212,191,0.3);
    border-radius: 8px; color: #2dd4bf; padding: 6px 16px;
    font-size: 13px; font-weight: 600; cursor: pointer;
    transition: all 0.2s; font-family: inherit;
  }
  .copy-btn:hover { background: rgba(45,212,191,0.22); border-color: rgba(45,212,191,0.5); }
  .copy-btn.copied { background: rgba(52,211,153,0.2); border-color: rgba(52,211,153,0.4); color: #34d399; }

  /* ---- Pain cards ---- */
  .pain-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px; padding: 24px;
    text-align: left; transition: all 0.3s;
  }
  .pain-card:hover {
    background: rgba(239,68,68,0.03);
    border-color: rgba(239,68,68,0.12);
  }
  .pain-icon {
    width: 36px; height: 36px; border-radius: 10px;
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.15);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
  }

  /* ---- Feature cards ---- */
  .feature-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px; padding: 28px;
    transition: all 0.3s;
  }
  .feature-card:hover {
    background: rgba(124,58,237,0.05);
    border-color: rgba(124,58,237,0.3);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(124,58,237,0.1);
  }
  .feature-icon-box {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
  }
  .feature-icon-box.purple { background: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.25); color: #a78bfa; }
  .feature-icon-box.cyan { background: rgba(45,212,191,0.12); border: 1px solid rgba(45,212,191,0.25); color: #5eead4; }
  .feature-icon-box.amber { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25); color: #fbbf24; }
  .feature-icon-box.emerald { background: rgba(52,211,153,0.12); border: 1px solid rgba(52,211,153,0.25); color: #6ee7b7; }

  .code-snippet {
    background: #060b17;
    border: 1px solid rgba(255,255,255,0.06);
    border-left: 3px solid rgba(124,58,237,0.4);
    border-radius: 10px; padding: 16px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px; color: #94a3b8;
    white-space: pre; line-height: 1.8; overflow-x: auto;
  }

  /* ---- Terminal window ---- */
  .terminal {
    background: #060b17;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; overflow: hidden;
  }
  .terminal-header {
    background: #0a1020; padding: 12px 16px;
    display: flex; align-items: center; gap: 7px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .terminal-dot { width: 12px; height: 12px; border-radius: 50%; }

  /* Agent badges */
  .agent-badge {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    color: #64748b; transition: color 0.3s;
  }
  .agent-badge:hover { color: #a78bfa; }
  .agent-badge span {
    font-size: 12px; font-weight: 600; letter-spacing: 0.02em;
  }

  .glow-border-purple {
    border-color: rgba(124,58,237,0.3);
    box-shadow: 0 0 30px rgba(124,58,237,0.1), inset 0 0 30px rgba(124,58,237,0.03);
  }

  /* ---- Command rows ---- */
  .cmd-row {
    display: flex; align-items: baseline;
    gap: 16px; flex-wrap: wrap;
    padding: 6px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .cmd-row:last-child { border-bottom: none; }
  .cmd-row code { min-width: 300px; }

  /* ---- Animations ---- */
  .logo-tilted {
    transform: rotate(12deg);
    transition: transform 0.3s ease;
  }
  .logo-tilted:hover {
    transform: rotate(5deg) scale(1.05);
  }

  @keyframes fadeIn { from { opacity:0 } to { opacity:1 } }
  @keyframes slideUp { from { opacity:0; transform:translateY(28px) } to { opacity:1; transform:translateY(0) } }
  .animate-fade-in { animation: fadeIn 0.8s ease-out both; }
  .animate-slide-up { animation: slideUp 0.8s ease-out both; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0a0f1e; }
  ::-webkit-scrollbar-thumb { background: #2d3748; border-radius: 3px; }

  @media (max-width: 768px) {
    .cmd-row { flex-direction: column; gap: 4px; }
    .cmd-row code { min-width: auto; }
  }

  /* ========================================
     LIGHT MODE OVERRIDES
     Keep all dark-mode CSS above untouched.
