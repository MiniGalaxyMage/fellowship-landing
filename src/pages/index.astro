                <p class="text-slate-500 text-xs leading-relaxed">
                  Auto-spec → write → review → scribe. Zero hand-holding.
                  Add <code class="text-purple-300">--review</code> for human-in-the-loop diff approval.
                </p>
              </div>
            </div>

            <div class="border-t border-slate-800/60"></div>

            <div class="how-step">
              <div class="step-number">3</div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                  <code class="text-cyan-400 font-medium">git push</code>
                  <span class="text-slate-600"># Ship it</span>
                </div>
                <p class="text-slate-500 text-xs leading-relaxed">
                  Code reviewed, changelog updated, memory saved. Done.
                </p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

