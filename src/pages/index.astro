      <div class="animate-fade-in">
        <img
          src="/logo.png"
          alt="Fellowship"
          width="96"
          height="96"
          class="mx-auto mb-6 drop-shadow-[0_0_40px_rgba(124,58,237,0.6)]"
        />
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-300 text-sm mb-8 font-mono">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse-slow"></span>
          v1.0 · Open Source · MIT
        </div>
      </div>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-[1.1] animate-slide-up" style="animation-delay: 0.1s">
        Your AI Agents.<br />
        <span class="gradient-text">One Team.</span><br />
        One Command.
      </h1>

      <p class="text-xl text-slate-400 max-w-2xl mb-12 leading-relaxed animate-slide-up" style="animation-delay: 0.2s">
        Fellowship orchestrates AI coding agents with specs, reviews, and memory —
        so you ship better code, faster.
      </p>

      <!-- Install CTA -->
      <div class="w-full max-w-lg mb-6 animate-slide-up" style="animation-delay: 0.3s">
        <div class="terminal-cta group" id="install-box">
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <span class="text-cyan-400 font-mono font-medium select-none flex-shrink-0">$</span>
            <code class="text-white font-mono text-sm md:text-base truncate" id="install-cmd">npm install -g fellowship-cli</code>
          </div>
          <button
            onclick="copyInstall(this)"
            class="copy-btn flex-shrink-0 ml-4"
            aria-label="Copy install command"
          >
            Copy
          </button>
        </div>
      </div>

      <a
        href="https://github.com/MiniGalaxyMage/fellowship"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors duration-200 text-sm animate-slide-up"
        style="animation-delay: 0.4s"
      >
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        View on GitHub →
      </a>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-slate-600 animate-bounce" aria-hidden="true">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </section>

    <!-- ===== PITCH ===== -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <p class="text-center text-slate-500 text-xs uppercase tracking-widest mb-12 font-mono">Sound familiar?</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-20">
          <div class="pain-card">
            <div class="text-red-400 text-lg mb-3 font-mono">✗</div>
            <p class="text-slate-300 font-medium leading-snug">"AI agents write code without context"</p>
          </div>
          <div class="pain-card">
            <div class="text-red-400 text-lg mb-3 font-mono">✗</div>
            <p class="text-slate-300 font-medium leading-snug">"No spec means no quality control"</p>
          </div>
          <div class="pain-card">
            <div class="text-red-400 text-lg mb-3 font-mono">✗</div>
            <p class="text-slate-300 font-medium leading-snug">"Every run starts from zero — no memory"</p>
          </div>
        </div>

        <div class="text-center">
          <h2 class="text-4xl md:text-5xl font-bold gradient-text mb-4">Fellowship fixes this.</h2>
          <p class="text-slate-400 text-lg">Orchestrate your AI agents like a real engineering team.</p>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Built for disciplined AI development</h2>
        <p class="text-slate-400 text-center mb-16 max-w-2xl mx-auto">
          Three pillars that transform ad-hoc AI prompts into a structured engineering process.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- Feature 1 -->
          <div class="feature-card">
            <div class="feature-icon mb-4">
              <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-purple-400">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-3">Spec-First Runs</h3>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              Every task starts with a plan. Fellowship auto-generates a spec from your codebase context before writing a single line.
            </p>
            <div class="code-snippet">
<span class="text-cyan-400">$</span> fellowship run "add JWT auth"

<span class="text-yellow-300">📋</span> Generating spec...
<span class="text-emerald-400">✅</span> spec/<span class="text-purple-300">001-jwt-auth.md</span>
   <span class="text-slate-500">12 acceptance criteria</span>
   <span class="text-slate-500">4 files in scope</span></div>
          </div>

          <!-- Feature 2 -->
          <div class="feature-card">
            <div class="feature-icon mb-4">
              <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-cyan-400">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-3">Writer-Reviewer</h3>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              One agent writes, another reviews. Automated quality gates with human override when you want it.
            </p>
            <div class="code-snippet">
<span class="text-yellow-300">🤖</span> Writer <span class="text-slate-500">(claude-sonnet)</span>
   implementing spec...

<span class="text-yellow-300">🔍</span> Reviewer <span class="text-slate-500">(claude-opus)</span>
   checking criteria...
   <span class="text-emerald-400">✅ 12/12 criteria met</span></div>
          </div>

          <!-- Feature 3 -->
          <div class="feature-card">
            <div class="feature-icon mb-4">
              <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-emerald-400">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-3">Persistent Memory</h3>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              Learnings, gotchas, architecture decisions — they persist across runs. Your agents get smarter over time.
            </p>
            <div class="code-snippet">
<span class="text-slate-500"># .fellowship/memory.yaml</span>
gotchas:
  - <span class="text-emerald-300">"Use bcrypt rounds ≥ 12"</span>
  - <span class="text-emerald-300">"JWT secret in .env only"</span>
patterns:
  - <span class="text-cyan-300">"Repository pattern for DB"</span></div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section class="py-24 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Three commands. Better code.</h2>
        <p class="text-slate-400 text-center mb-16">Get from idea to PR in minutes, not hours.</p>

        <div class="terminal shadow-2xl shadow-black/50">
          <div class="terminal-header">
            <div class="terminal-dot" style="background:#ff5f57"></div>
            <div class="terminal-dot" style="background:#ffbd2e"></div>
            <div class="terminal-dot" style="background:#28c840"></div>
            <span class="ml-3 text-slate-500 text-xs font-mono">fellowship</span>
          </div>
          <div class="p-6 md:p-8 space-y-8 font-mono text-sm">

            <div class="how-step">
              <div class="step-number">1</div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
