---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fellowship — Your AI Agents Remember Everything</title>
  <meta name="description" content="The CLI that gives AI coding agents memory, specs, and code review. Day 30 agents know what they learned on Day 1." />
  <meta property="og:title" content="Fellowship — Your AI Agents Remember Everything" />
  <meta property="og:description" content="The CLI that gives AI coding agents memory, specs, and code review. Day 30 agents know what they learned on Day 1." />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#0a0f1e] text-white font-sans antialiased overflow-x-hidden">

  <!-- Background -->
  <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
    <div class="bg-grid"></div>
    <div class="absolute top-[-200px] left-1/2 -translate-x-1/2 w-[1200px] h-[800px] bg-purple-600/8 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-[-100px] right-[-200px] w-[800px] h-[600px] bg-cyan-500/5 rounded-full blur-[120px]"></div>
  </div>

  <main class="relative z-10">

    <!-- ===== HERO ===== -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-20 pb-24 text-center">
      
      <!-- Logo — BIG, with glow, blended into bg -->
      <div class="mb-8 relative animate-fade-in">
        <div class="absolute inset-0 scale-150 bg-purple-600/20 rounded-full blur-[80px]"></div>
        <img
          src="/logo.png"
          alt="Fellowship"
          width="180"
          height="180"
          class="relative mx-auto drop-shadow-[0_0_60px_rgba(124,58,237,0.5)] rounded-3xl"
          style="mix-blend-mode: lighten;"
        />
      </div>

      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-300 text-sm mb-10 font-mono animate-fade-in" style="animation-delay:0.15s">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Open Source · MIT Licensed
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tight mb-8 leading-[1.05] animate-slide-up" style="animation-delay:0.2s">
        Your AI Agents<br/>
        <span class="gradient-text-hero">Remember Everything.</span>
      </h1>

      <p class="text-xl md:text-2xl text-slate-400 max-w-3xl mb-14 leading-relaxed animate-slide-up" style="animation-delay:0.35s">
        Fellowship gives coding agents <strong class="text-white">persistent memory</strong>, 
        <strong class="text-white">auto-generated specs</strong>, and 
        <strong class="text-white">code review</strong>.<br class="hidden md:block"/>
        <span class="text-slate-500">Your agent on day 30 knows what it learned on day 1.</span>
      </p>

      <!-- Install CTA -->
      <div class="w-full max-w-xl mb-8 animate-slide-up" style="animation-delay:0.5s">
        <div class="terminal-cta group">
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <span class="text-emerald-400 font-mono font-semibold select-none flex-shrink-0">$</span>
            <code class="text-white font-mono text-base md:text-lg truncate">npm install -g fellowship-cli</code>
          </div>
          <button onclick="copyInstall(this)" class="copy-btn" aria-label="Copy install command">
            Copy
          </button>
        </div>
      </div>

      <div class="flex items-center gap-6 animate-slide-up" style="animation-delay:0.6s">
        <a href="https://github.com/MiniGalaxyMage/fellowship" target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition text-sm font-medium">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          Star on GitHub
        </a>
        <span class="text-slate-700">·</span>
        <a href="#features" class="text-slate-400 hover:text-white transition text-sm font-medium">
          See features ↓
        </a>
      </div>
    </section>

    <!-- ===== THE PROBLEM ===== -->
    <section class="py-28 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-slate-600 text-xs uppercase tracking-[0.25em] mb-6 font-mono">The problem with AI coding agents</p>
        
        <h2 class="text-3xl md:text-5xl font-bold mb-16 leading-tight">
          Every tool gives you an agent.<br/>
          <span class="text-slate-500">None of them give it a <em class="gradient-text-hero not-italic">brain</em>.</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="pain-card">
            <div class="text-2xl mb-3">🧠</div>
            <p class="text-slate-300 font-semibold mb-2">Amnesia</p>
            <p class="text-slate-500 text-sm leading-relaxed">Every run starts from zero. Your agent makes the same mistakes it made yesterday.</p>
          </div>
          <div class="pain-card">
            <div class="text-2xl mb-3">🎯</div>
            <p class="text-slate-300 font-semibold mb-2">No plan</p>
            <p class="text-slate-500 text-sm leading-relaxed">You say "add auth" and pray. No spec, no criteria, no way to verify the output.</p>
          </div>
          <div class="pain-card">
            <div class="text-2xl mb-3">👁️</div>
            <p class="text-slate-300 font-semibold mb-2">No review</p>
            <p class="text-slate-500 text-sm leading-relaxed">Code goes straight to your branch. No second pair of eyes. No quality gate.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== KILLER FEATURE: MEMORY ===== -->
    <section class="py-28 px-6 relative" id="features">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/5 to-transparent pointer-events-none"></div>
      <div class="max-w-5xl mx-auto relative">
        
        <div class="text-center mb-16">
          <p class="text-emerald-400 text-xs uppercase tracking-[0.25em] mb-4 font-mono font-semibold">The killer feature</p>
          <h2 class="text-4xl md:text-6xl font-black mb-6">
            Agents that <span class="gradient-text-hero">learn</span>.
          </h2>
          <p class="text-slate-400 text-xl max-w-2xl mx-auto">
            Fellowship stores learnings, gotchas, and architecture decisions. 
            Every run builds on the last.
          </p>
        </div>

        <!-- Day 1 vs Day 30 comparison -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          
          <!-- Day 1 -->
          <div class="terminal">
            <div class="terminal-header">
              <div class="terminal-dot" style="background:#ff5f57"></div>
              <div class="terminal-dot" style="background:#ffbd2e"></div>
              <div class="terminal-dot" style="background:#28c840"></div>
              <span class="ml-3 text-slate-500 text-xs font-mono">Day 1</span>
            </div>
            <div class="p-5 font-mono text-xs leading-relaxed space-y-1">
              <div><span class="text-cyan-400">$</span> <span class="text-slate-400">fellowship run "add API endpoint"</span></div>
              <div class="text-slate-600">&nbsp;</div>
              <div><span class="text-yellow-300">📋</span> <span class="text-slate-400">Spec generated</span></div>
              <div><span class="text-yellow-300">🤖</span> <span class="text-slate-400">Writing code...</span></div>
              <div><span class="text-emerald-400">✅</span> <span class="text-slate-300">Done</span></div>
              <div><span class="text-yellow-300">💡</span> <span class="text-amber-300">Learned: "Use bcrypt rounds ≥ 12"</span></div>
              <div><span class="text-yellow-300">💡</span> <span class="text-amber-300">Learned: "Always validate JWT server-side"</span></div>
              <div class="text-slate-600">&nbsp;</div>
              <div class="text-slate-600 italic">memory: 2 learnings saved</div>
            </div>
          </div>

          <!-- Day 30 -->
          <div class="terminal glow-border-purple">
            <div class="terminal-header">
              <div class="terminal-dot" style="background:#ff5f57"></div>
              <div class="terminal-dot" style="background:#ffbd2e"></div>
              <div class="terminal-dot" style="background:#28c840"></div>
              <span class="ml-3 text-emerald-400 text-xs font-mono font-semibold">Day 30</span>
            </div>
            <div class="p-5 font-mono text-xs leading-relaxed space-y-1">
              <div><span class="text-cyan-400">$</span> <span class="text-slate-400">fellowship run "add payment system"</span></div>
              <div class="text-slate-600">&nbsp;</div>
              <div><span class="text-yellow-300">📋</span> <span class="text-slate-400">Spec generated with <span class="text-emerald-400 font-semibold">47 learnings</span></span></div>
              <div><span class="text-purple-400">🔍</span> <span class="text-slate-400">Retrieved: <span class="text-purple-300">"Always use decimal for money"</span></span></div>
              <div><span class="text-purple-400">🔍</span> <span class="text-slate-400">Retrieved: <span class="text-purple-300">"Validate webhook signatures"</span></span></div>
              <div><span class="text-purple-400">🔍</span> <span class="text-slate-400">Retrieved: <span class="text-purple-300">"Idempotency keys on all charges"</span></span></div>
              <div><span class="text-yellow-300">🤖</span> <span class="text-slate-400">Writing code <span class="text-slate-600">(already knows your patterns)</span></span></div>
              <div><span class="text-emerald-400">✅</span> <span class="text-emerald-300 font-semibold">Zero mistakes. First try.</span></div>
            </div>
          </div>
        </div>

        <p class="text-center text-slate-500 text-sm">
          Same agent. Same codebase. <strong class="text-slate-300">30 days of accumulated wisdom.</strong>
        </p>
      </div>
    </section>

    <!-- ===== FEATURES GRID ===== -->
    <section class="py-28 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold mb-4">Everything you need.</h2>
          <p class="text-slate-400 text-lg">From planning to shipping. One CLI.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <!-- Spec-First -->
          <div class="feature-card">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-purple-500/15 border border-purple-500/30 flex items-center justify-center">
                <span class="text-lg">📋</span>
              </div>
              <h3 class="text-lg font-bold">Spec-First Runs</h3>
            </div>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              Every task auto-generates a spec with acceptance criteria from your codebase context. No more "just wing it" coding.
            </p>
            <div class="code-snippet"><span class="text-cyan-400">$</span> fellowship run "add user roles" --review-spec

<span class="text-yellow-300">📋</span> Spec: <span class="text-purple-300">002-user-roles.md</span>
   <span class="text-slate-500">8 acceptance criteria</span>
   <span class="text-slate-500">3 gotchas applied</span>
   
<span class="text-cyan-400">?</span> Review spec before implementation? <span class="text-emerald-400">[Y/n]</span></div>
          </div>

          <!-- Writer-Reviewer -->
          <div class="feature-card">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-cyan-500/15 border border-cyan-500/30 flex items-center justify-center">
                <span class="text-lg">🔍</span>
              </div>
              <h3 class="text-lg font-bold">Writer-Reviewer Pattern</h3>
            </div>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              One agent writes, another reviews against the spec. Automated quality gates — with human override via <code class="text-purple-300">--review</code>.
            </p>
            <div class="code-snippet"><span class="text-yellow-300">🤖</span> Writer <span class="text-slate-600">(sonnet)</span> implementing...
<span class="text-yellow-300">🔍</span> Reviewer <span class="text-slate-600">(opus)</span> checking...

<span class="text-emerald-400">✅</span> 8/8 criteria met
<span class="text-yellow-300">📝</span> Scribe updated CHANGELOG.md
<span class="text-emerald-400">🚀</span> <span class="text-emerald-300">Ready to push!</span></div>
          </div>

          <!-- Hire -->
          <div class="feature-card">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-amber-500/15 border border-amber-500/30 flex items-center justify-center">
                <span class="text-lg">🧙‍♂️</span>
              </div>
              <h3 class="text-lg font-bold">Hire Your Team</h3>
            </div>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              Build your agent team through conversation. Define roles, models, and behaviors — Fellowship creates the config.
            </p>
            <div class="code-snippet"><span class="text-cyan-400">$</span> fellowship hire

<span class="text-purple-400">🧙</span> What role? <span class="text-white">backend engineer</span>
<span class="text-purple-400">🧙</span> Which model? <span class="text-white">claude-sonnet</span>
<span class="text-purple-400">🧙</span> Specialties? <span class="text-white">APIs, databases</span>

<span class="text-emerald-400">✅</span> Added <span class="text-purple-300">forge</span> to team.yaml</div>
          </div>

          <!-- Scribe -->
          <div class="feature-card">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/15 border border-emerald-500/30 flex items-center justify-center">
                <span class="text-lg">📝</span>
              </div>
              <h3 class="text-lg font-bold">Auto Documentation</h3>
            </div>
            <p class="text-slate-400 text-sm mb-5 leading-relaxed">
              The Scribe agent updates your CHANGELOG, README, and API docs after every run. Documentation that never goes stale.
            </p>
            <div class="code-snippet"><span class="text-cyan-400">$</span> fellowship run "add payments" --scribe

<span class="text-slate-500">...</span>
<span class="text-yellow-300">📝</span> Scribe: updated CHANGELOG.md
<span class="text-yellow-300">📝</span> Scribe: updated docs/api.md
<span class="text-yellow-300">📝</span> Scribe: updated README.md
<span class="text-emerald-400">✅</span> <span class="text-slate-400">3 docs updated automatically</span></div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== ALL COMMANDS ===== -->
    <section class="py-28 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold mb-4">Simple commands. Powerful results.</h2>
          <p class="text-slate-400 text-lg">Everything from setup to shipping.</p>
        </div>

        <div class="terminal shadow-2xl shadow-purple-900/10">
          <div class="terminal-header">
            <div class="terminal-dot" style="background:#ff5f57"></div>
            <div class="terminal-dot" style="background:#ffbd2e"></div>
            <div class="terminal-dot" style="background:#28c840"></div>
            <span class="ml-3 text-slate-500 text-xs font-mono">fellowship commands</span>
          </div>
          <div class="p-6 md:p-8 font-mono text-sm space-y-5">
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship init</code>
              <span class="text-slate-600">Set up a new project</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship adopt</code>
              <span class="text-slate-600">Add to an existing repo</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship hire</code>
              <span class="text-slate-600">Build your agent team</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship run <span class="text-purple-300">"task"</span></code>
              <span class="text-slate-600">Spec → write → review → done</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship run <span class="text-purple-300">"task"</span> --review</code>
              <span class="text-slate-600">Human-in-the-loop diff review</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship spec <span class="text-purple-300">"task"</span></code>
              <span class="text-slate-600">Generate spec without implementing</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship search <span class="text-purple-300">"query"</span></code>
              <span class="text-slate-600">Search project learnings</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship scribe</code>
              <span class="text-slate-600">Generate docs from current code</span>
            </div>
            <div class="cmd-row">
              <code class="text-cyan-400">fellowship status</code>
              <span class="text-slate-600">Dashboard of recent runs</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="py-32 px-6 relative">
      <div class="absolute inset-0 bg-gradient-to-t from-purple-900/10 to-transparent pointer-events-none"></div>
      <div class="max-w-2xl mx-auto text-center relative">
        
        <h2 class="text-4xl md:text-6xl font-black mb-6">
          Stop prompting.<br/>
          <span class="gradient-text-hero">Start orchestrating.</span>
        </h2>
        <p class="text-slate-400 mb-12 text-lg">
          One install. Zero config. Agents that actually remember.
        </p>

        <div class="w-full max-w-xl mx-auto mb-10">
          <div class="terminal-cta">
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <span class="text-emerald-400 font-mono font-semibold select-none flex-shrink-0">$</span>
              <code class="text-white font-mono text-base md:text-lg truncate">npm install -g fellowship-cli</code>
            </div>
            <button onclick="copyInstall(this)" class="copy-btn" aria-label="Copy install command">
              Copy
            </button>
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-6 mb-16">
          <a href="https://github.com/MiniGalaxyMage/fellowship" target="_blank" rel="noopener"
            class="gh-btn">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            ⭐ Star on GitHub
          </a>
        </div>

        <p class="text-slate-700 text-sm">
          Open source · MIT Licensed · Works with Claude Code, Codex, and any CLI agent
        </p>
      </div>
    </section>

  </main>

  <script>
    function copyInstall(btn) {
      const text = 'npm install -g fellowship-cli';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 2000);
      });
    }
  </script>

</body>
</html>

<style is:global>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  .bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(124,58,237,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,58,237,0.03) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  /* ---- Gradients ---- */
  .gradient-text-hero {
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 30%, #2dd4bf 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ---- Terminal CTA ---- */
  .terminal-cta {
    display: flex; align-items: center;
    background: #060b17;
    border: 1px solid rgba(45,212,191,0.3);
    border-radius: 12px;
    padding: 16px 20px;
    box-shadow: 0 0 40px rgba(45,212,191,0.08), 0 0 80px rgba(45,212,191,0.04);
    animation: ctaGlow 3s ease-in-out infinite;
  }
  @keyframes ctaGlow {
    0%,100% { box-shadow: 0 0 40px rgba(45,212,191,0.08), 0 0 80px rgba(45,212,191,0.04); }
    50% { box-shadow: 0 0 50px rgba(45,212,191,0.15), 0 0 100px rgba(45,212,191,0.07); }
  }

  .copy-btn {
    background: rgba(45,212,191,0.12); border: 1px solid rgba(45,212,191,0.3);
    border-radius: 8px; color: #2dd4bf; padding: 6px 16px;
    font-size: 13px; font-weight: 600; cursor: pointer;
