    <!-- ===== INSTALL CTA ===== -->
    <section class="py-32 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">Ready to ship smarter?</h2>
        <p class="text-slate-400 mb-12 text-lg">One command to get started. No configuration required.</p>

        <div class="w-full mb-8">
          <div class="terminal-cta" id="install-box-2">
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <span class="text-cyan-400 font-mono font-medium select-none flex-shrink-0">$</span>
              <code class="text-white font-mono text-sm md:text-base truncate">npm install -g fellowship-cli</code>
