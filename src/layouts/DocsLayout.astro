---
interface Props {
  title: string;
  description: string;
  activeNav: 'getting-started' | 'commands' | 'concepts' | 'configuration';
}

const { title, description, activeNav } = Astro.props;

const navItems = [
  { id: 'getting-started', label: 'Getting Started', href: '/docs' },
  { id: 'commands', label: 'Commands', href: '/docs/commands' },
  { id: 'concepts', label: 'Concepts', href: '/docs/concepts' },
  { id: 'configuration', label: 'Configuration', href: '/docs/configuration' },
] as const;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Fellowship Docs</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} — Fellowship Docs`} />
  <meta property="og:description" content={description} />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#0a0f1e] text-white font-sans antialiased">

  <!-- Background effects -->
  <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
    <div class="docs-grid"></div>
    <div class="absolute top-[-200px] left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-purple-600/5 rounded-full blur-[150px]"></div>
  </div>

  <!-- Mobile header -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-[#0a0f1e]/95 backdrop-blur-md border-b border-white/[0.06]">
    <div class="flex items-center justify-between px-4 h-14">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/logo.png" alt="Fellowship" class="w-7 h-7" />
        <span class="font-semibold text-sm text-white/90">Fellowship <span class="text-purple-400 font-medium">Docs</span></span>
      </a>
      <button
        id="mobile-menu-btn"
        class="flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 text-slate-400 hover:text-white hover:border-white/20 transition-colors"
        aria-label="Toggle navigation"
      >
        <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </header>

  <!-- Sidebar overlay (mobile) -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden" aria-hidden="true"></div>

  <!-- Sidebar -->
  <aside
    id="sidebar"
    class="fixed top-0 left-0 z-40 h-screen w-[272px] bg-[#0a0f1e]/98 backdrop-blur-xl border-r border-white/[0.06] flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out"
  >
    <!-- Logo -->
    <div class="hidden lg:flex items-center gap-2.5 px-5 h-16 border-b border-white/[0.06] shrink-0">
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.png" alt="Fellowship" class="w-7 h-7 group-hover:scale-105 transition-transform" />
        <span class="font-semibold text-[15px] text-white/90">Fellowship <span class="text-purple-400 font-medium">Docs</span></span>
      </a>
    </div>

    <!-- Mobile spacer for fixed header -->
    <div class="h-14 shrink-0 lg:hidden"></div>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto px-3 py-4">
      <div class="text-[10.5px] font-semibold uppercase tracking-[0.08em] text-slate-500 px-3 mb-2">Documentation</div>
      <ul class="space-y-0.5">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13.5px] font-medium transition-all duration-200',
                activeNav === item.id
                  ? 'bg-purple-500/10 text-purple-300 border border-purple-500/20'
                  : 'text-slate-400 hover:text-slate-200 hover:bg-white/[0.04] border border-transparent',
              ]}
            >
              <span class:list={[
                'w-1.5 h-1.5 rounded-full shrink-0 transition-colors',
                activeNav === item.id ? 'bg-purple-400' : 'bg-slate-600',
              ]} />
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- External links -->
      <div class="text-[10.5px] font-semibold uppercase tracking-[0.08em] text-slate-500 px-3 mt-8 mb-2">Links</div>
      <ul class="space-y-0.5">
        <li>
          <a href="/" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13.5px] font-medium text-slate-400 hover:text-slate-200 hover:bg-white/[0.04] transition-all duration-200">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
            Home
          </a>
        </li>
        <li>
          <a href="https://github.com/MiniGalaxyMage/fellowship" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13.5px] font-medium text-slate-400 hover:text-slate-200 hover:bg-white/[0.04] transition-all duration-200">
            <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" /></svg>
            GitHub
          </a>
        </li>
        <li>
          <a href="https://www.npmjs.com/package/fellowship-cli" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13.5px] font-medium text-slate-400 hover:text-slate-200 hover:bg-white/[0.04] transition-all duration-200">
            <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0h-2.666V8.667h2.666v5.331zm12 0h-1.333v-4h-1.334v4h-1.333v-4h-1.334v4h-2.666V8.667h8v5.331z" /></svg>
            npm
          </a>
        </li>
      </ul>
    </nav>

    <!-- Version badge -->
    <div class="px-5 py-3 border-t border-white/[0.06] shrink-0">
      <span class="text-[11px] text-slate-500 font-mono">fellowship-cli v0.4.5</span>
    </div>
  </aside>

  <!-- Main content -->
  <main class="lg:pl-[272px] relative z-10">
    <div class="pt-14 lg:pt-0">
      <div class="max-w-3xl mx-auto px-6 sm:px-8 py-12 lg:py-16">
        <slot />
      </div>
    </div>
  </main>

  <style is:global>
    .docs-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(124,58,237,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(124,58,237,0.02) 1px, transparent 1px);
      background-size: 64px 64px;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #2d3748; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #4a5568; }

    /* Docs prose */
    .docs-content h1 {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1.2;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, #a855f7 0%, #7c3aed 40%, #2dd4bf 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .docs-content h2 {
      font-size: 1.375rem;
      font-weight: 700;
      color: #e2e8f0;
      margin-top: 3rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .docs-content h3 {
      font-size: 1.1rem;
      font-weight: 600;
      color: #cbd5e1;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    .docs-content p {
      color: #94a3b8;
      line-height: 1.75;
      margin-bottom: 1rem;
    }

    .docs-content strong {
      color: #e2e8f0;
      font-weight: 600;
    }

    .docs-content a {
      color: #a78bfa;
      text-decoration: underline;
      text-decoration-color: rgba(167,139,250,0.3);
      text-underline-offset: 2px;
      transition: text-decoration-color 0.2s;
    }
    .docs-content a:hover {
      text-decoration-color: rgba(167,139,250,0.8);
    }

    .docs-content ul, .docs-content ol {
      color: #94a3b8;
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }

    .docs-content ul { list-style-type: disc; }
    .docs-content ol { list-style-type: decimal; }

    .docs-content li {
      margin-bottom: 0.375rem;
      line-height: 1.7;
    }

    .docs-content li strong {
      color: #e2e8f0;
    }

    .docs-content code:not(pre code) {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8125em;
      background: rgba(124,58,237,0.1);
      border: 1px solid rgba(124,58,237,0.2);
      color: #c4b5fd;
      padding: 0.125rem 0.375rem;
      border-radius: 4px;
    }

    .docs-content .subtitle {
      font-size: 1.05rem;
      color: #64748b;
      margin-bottom: 2.5rem;
    }

    /* Terminal code blocks */
    .terminal-block {
      background: #060b17;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .terminal-block-header {
      background: #0a1020;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 6px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .terminal-block-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    .terminal-block-title {
      margin-left: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: #475569;
    }

    .terminal-block pre {
      padding: 16px 18px;
      overflow-x: auto;
      margin: 0;
    }

    .terminal-block code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12.5px;
      line-height: 1.8;
      color: #94a3b8;
    }

    /* Syntax highlighting in terminal blocks */
    .terminal-block .comment { color: #475569; }
    .terminal-block .cmd { color: #2dd4bf; }
    .terminal-block .flag { color: #a78bfa; }
    .terminal-block .string { color: #fbbf24; }
    .terminal-block .output { color: #64748b; }
    .terminal-block .success { color: #34d399; }
    .terminal-block .key { color: #c4b5fd; }
    .terminal-block .value { color: #94a3b8; }
    .terminal-block .punct { color: #475569; }

    /* Config blocks (YAML style) */
    .config-block {
      background: #060b17;
      border: 1px solid rgba(255,255,255,0.08);
      border-left: 3px solid rgba(124,58,237,0.4);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .config-block pre {
      padding: 16px 18px;
      overflow-x: auto;
      margin: 0;
    }

    .config-block code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12.5px;
      line-height: 1.8;
      color: #94a3b8;
    }

    /* Tables */
    .docs-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
    }

    .docs-table th {
      text-align: left;
      padding: 10px 14px;
      font-weight: 600;
      color: #cbd5e1;
      background: rgba(255,255,255,0.03);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      font-size: 0.8125rem;
    }

    .docs-table td {
      padding: 10px 14px;
      color: #94a3b8;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .docs-table td code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      background: rgba(124,58,237,0.1);
      border: 1px solid rgba(124,58,237,0.2);
      color: #c4b5fd;
      padding: 1px 6px;
      border-radius: 4px;
    }

    .docs-table tr:last-child td {
      border-bottom: none;
    }

    /* Info callout boxes */
    .callout {
      border-radius: 10px;
      padding: 16px 18px;
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
      line-height: 1.7;
      color: #94a3b8;
    }

    .callout-info {
      background: rgba(45,212,191,0.06);
      border: 1px solid rgba(45,212,191,0.15);
    }

    .callout-info strong { color: #2dd4bf; }

    .callout-purple {
      background: rgba(124,58,237,0.06);
      border: 1px solid rgba(124,58,237,0.15);
    }

    .callout-purple strong { color: #a78bfa; }

    /* Prev/Next navigation */
    .docs-nav-link {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 16px 20px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.06);
      background: rgba(255,255,255,0.02);
      transition: all 0.2s;
      text-decoration: none;
    }

    .docs-nav-link:hover {
      background: rgba(124,58,237,0.05);
      border-color: rgba(124,58,237,0.2);
    }

    .docs-nav-link .label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #64748b;
    }

    .docs-nav-link .title {
      font-size: 14px;
      font-weight: 600;
      color: #a78bfa;
    }

    /* Flow diagram */
    .flow-diagram {
      background: #060b17;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 1.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      line-height: 1.6;
      color: #64748b;
      overflow-x: auto;
      white-space: pre;
    }

    .flow-diagram .highlight { color: #2dd4bf; }
    .flow-diagram .accent { color: #a78bfa; }
    .flow-diagram .muted { color: #334155; }
  </style>

  <script is:inline>
    const btn = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    function toggleMenu() {
      const isOpen = !sidebar.classList.contains('-translate-x-full');
      sidebar.classList.toggle('-translate-x-full', isOpen);
      sidebar.classList.toggle('translate-x-0', !isOpen);
      overlay.classList.toggle('hidden', isOpen);
      menuIcon.classList.toggle('hidden', !isOpen);
      closeIcon.classList.toggle('hidden', isOpen);
    }

    btn.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);

    // Close on nav link click (mobile)
    sidebar.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        if (window.innerWidth < 1024) toggleMenu();
      });
    });
  </script>
</body>
</html>
